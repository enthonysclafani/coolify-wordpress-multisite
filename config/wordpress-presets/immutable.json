{
  "schema": 1,
  "name": "immutable",
  "wordpress": {
    "environment": "production",
    "permalink_structure": "/%postname%/",
    "search_engine_visibility": true,
    "delete_default_content": true,
    "update_policy": "disabled",
    "disallow_file_edit": true,
    "disallow_file_mods": true
  },
  "plugins": [
    {
      "slug": "litespeed-cache",
      "version": "7.8.1",
      "activation": "auto",
      "required": true
    },
    {
      "slug": "redis-cache",
      "version": "2.8.0",
      "activation": "auto",
      "required": true
    }
  ],
  "themes": [],
  "multisite": {
    "registration": "none",
    "upload_space_mb": 1024,
    "upload_filetypes": "jpg jpeg png gif webp avif heic pdf doc docx xls xlsx zip mp3 mp4",
    "apply_to_existing_sites": false
  }
}
