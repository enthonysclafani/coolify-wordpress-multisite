WORDPRESS_DOMAIN=example.com
WORDPRESS_TITLE=Example Network
WORDPRESS_ADMIN_USER=networkadmin
WORDPRESS_ADMIN_EMAIL=admin@example.com
WORDPRESS_ADMIN_PASSWORD=change-me-with-at-least-12-characters
WORDPRESS_DB_HOST=db.example.internal:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=change-me
WORDPRESS_DB_SSL=true
WORDPRESS_REDIS_HOST=redis.example.internal
WORDPRESS_REDIS_PORT=6380
WORDPRESS_REDIS_SCHEME=tls
WORDPRESS_REDIS_USERNAME=default
WORDPRESS_REDIS_PASSWORD=change-me
WORDPRESS_BOOTSTRAP_PRESET=standard
WORDPRESS_IMAGE_TARGET=wordpress-suite
