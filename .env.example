# Dominio pubblico. In produzione usare il dominio reale senza path o porta.
WORDPRESS_DOMAIN=example.com
WORDPRESS_TITLE=Example Network
WORDPRESS_ADMIN_USER=networkadmin
WORDPRESS_ADMIN_EMAIL=admin@example.com
WORDPRESS_ADMIN_PASSWORD=change-me-with-at-least-12-characters

# Magic variables: Coolify genera automaticamente valori casuali persistenti.
# I placeholder servono soltanto per rendere esplicita la configurazione locale.
SERVICE_PASSWORD_MARIADB=change-me-mariadb-root
SERVICE_PASSWORD_WORDPRESS=change-me-wordpress-db

WORDPRESS_LOCALE=it_IT
WORDPRESS_TIMEZONE=Europe/Rome
WORDPRESS_DEBUG=false
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_SKIP_EMAIL=true
WORDPRESS_INSTALL_PLUGINS=true
WORDPRESS_ENABLE_REDIS=true
WORDPRESS_DISABLE_WP_CRON=true
WORDPRESS_CRON_INTERVAL_SECONDS=300
WORDPRESS_MEMORY_LIMIT=256M
WORDPRESS_MAX_MEMORY_LIMIT=512M
WORDPRESS_VERSION=7.0.2

PHP_UPLOAD_MAX_FILESIZE=1024M
PHP_POST_MAX_SIZE=1024M
PHP_MEMORY_LIMIT=512M
