# Identità e credenziali iniziali
WORDPRESS_DOMAIN=example.com
WORDPRESS_TITLE=Example Network
WORDPRESS_ADMIN_USER=networkadmin
WORDPRESS_ADMIN_EMAIL=admin@example.com
WORDPRESS_ADMIN_PASSWORD=change-me-with-at-least-12-characters
SERVICE_PASSWORD_MARIADB=change-me-mariadb-root
SERVICE_PASSWORD_MYSQL=change-me-mysql-root
SERVICE_PASSWORD_WORDPRESS=change-me-wordpress-db

# Stack, immagine e topologia
OPENLITESPEED_IMAGE=litespeedtech/openlitespeed:1.8.5-lsphp83
WORDPRESS_IMAGE_TARGET=final
WORDPRESS_VERSION=7.0.2
WP_CLI_VERSION=2.12.0
LITESPEED_CACHE_VERSION=7.8.1
REDIS_CACHE_VERSION=2.8.0
ELASTICPRESS_VERSION=5.3.3
# Richiesti solo quando si ricostruisce un target immutabile con versioni diverse.
LITESPEED_CACHE_SHA256=b4c550a197f30212ab59489f75eb00e3610253db9ee3d837b1e8f7bf8ba803a9
REDIS_CACHE_SHA256=f077ac8b9c154cee936d3872b0734d42f7fd7f350e68fe8b2b20a69e854980cd
ELASTICPRESS_SHA256=157cd901955a7da718301431f668e9abcac48d41b8392897c3c4ccc93e820813
WORDPRESS_LOCALE=it_IT
WORDPRESS_TIMEZONE=Europe/Rome
WORDPRESS_ENABLE_MULTISITE=true
WORDPRESS_MULTISITE_MODE=subdirectory
WORDPRESS_FILESYSTEM_MODE=mutable

# Bootstrap dichiarativo
WORDPRESS_BOOTSTRAP_PRESET=standard
WORDPRESS_BOOTSTRAP_MANIFEST=
WORDPRESS_BOOTSTRAP_MANIFEST_JSON=
WORDPRESS_MANIFEST_REAPPLY=false
WORDPRESS_INSTALL_PLUGINS=true
WORDPRESS_INSTALL_THEMES=true
WORDPRESS_SKIP_EMAIL=true
WORDPRESS_TABLE_PREFIX=wp_
WORDPRESS_DEBUG=false

# Runtime small | balanced | large; gli override granulari hanno precedenza
WORDPRESS_RUNTIME_PROFILE=balanced
WORDPRESS_MEMORY_LIMIT=256M
WORDPRESS_MAX_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=1024M
PHP_POST_MAX_SIZE=1024M
PHP_MEMORY_LIMIT=512M
PHP_MAX_EXECUTION_TIME=300
PHP_MAX_INPUT_TIME=300
PHP_MAX_INPUT_VARS=5000
PHP_LSAPI_CHILDREN=
LSAPI_AVOID_FORK=
PHP_OPCACHE_MEMORY_CONSUMPTION=
PHP_OPCACHE_INTERNED_STRINGS_BUFFER=
PHP_OPCACHE_MAX_ACCELERATED_FILES=
PHP_OPCACHE_VALIDATE_TIMESTAMPS=1
PHP_OPCACHE_REVALIDATE_FREQ=2
OLS_MAX_CONNECTIONS=
OLS_KEEP_ALIVE_TIMEOUT=5
OLS_MAX_REQUEST_BODY_SIZE=2047M
WORDPRESS_HEALTHCHECK_MODE=readiness

# Database interno standard. compose/external.yml usa WORDPRESS_DB_PASSWORD direttamente.
WORDPRESS_DB_HOST=mariadb:3306
WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=
WORDPRESS_DB_SSL=false
MARIADB_MAX_CONNECTIONS=200
MARIADB_INNODB_BUFFER_POOL_SIZE=256M
MYSQL_MAX_CONNECTIONS=200
MYSQL_INNODB_BUFFER_POOL_SIZE=256M

# Redis interno o esterno/ACL/TLS
WORDPRESS_ENABLE_REDIS=true
WORDPRESS_REDIS_HOST=redis
WORDPRESS_REDIS_PORT=6379
WORDPRESS_REDIS_SCHEME=tcp
WORDPRESS_REDIS_DATABASE=0
WORDPRESS_REDIS_USERNAME=
WORDPRESS_REDIS_PASSWORD=
WORDPRESS_REDIS_TLS_CA=
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=allkeys-lru

# Cron e worker opzionale (attivare il profilo con COMPOSE_PROFILES=worker)
WORDPRESS_DISABLE_WP_CRON=true
WORDPRESS_CRON_INTERVAL_SECONDS=300
WORDPRESS_WORKER_MODE=action-scheduler
WORDPRESS_WORKER_INTERVAL_SECONDS=30
WORDPRESS_ACTION_SCHEDULER_BATCH_SIZE=100
WORDPRESS_ACTION_SCHEDULER_BATCHES=1
WORDPRESS_ACTION_SCHEDULER_GROUP=
WORDPRESS_ACTION_SCHEDULER_HOOKS=
WORDPRESS_ACTION_SCHEDULER_CONCURRENT_BATCHES=1

# SMTP applicativo
WORDPRESS_SMTP_MODE=disabled
WORDPRESS_SMTP_HOST=
WORDPRESS_SMTP_PORT=587
WORDPRESS_SMTP_ENCRYPTION=tls
WORDPRESS_SMTP_AUTH=true
WORDPRESS_SMTP_USERNAME=
WORDPRESS_SMTP_PASSWORD=
WORDPRESS_SMTP_FROM_EMAIL=
WORDPRESS_SMTP_FROM_NAME=
WORDPRESS_SMTP_VERIFY_TLS=true
WORDPRESS_SMTP_TIMEOUT_SECONDS=15

# Media S3/S3-compatible. Impostare WORDPRESS_IMAGE_TARGET=wordpress-suite.
WORDPRESS_MEDIA_STORAGE=local
WORDPRESS_S3_BUCKET=
WORDPRESS_S3_REGION=
WORDPRESS_S3_ACCESS_KEY=
WORDPRESS_S3_SECRET_KEY=
WORDPRESS_S3_SESSION_TOKEN=
WORDPRESS_S3_ENDPOINT=
WORDPRESS_S3_BUCKET_URL=
WORDPRESS_S3_PATH_STYLE=true
WORDPRESS_S3_USE_INSTANCE_PROFILE=false
WORDPRESS_S3_AUTOENABLE=true
WORDPRESS_S3_USE_LOCAL=false
WORDPRESS_S3_OBJECT_ACL=private
WORDPRESS_S3_CACHE_CONTROL_SECONDS=31536000
WORDPRESS_S3_CHECKSUM_WHEN_REQUIRED=true

# Ricerca esterna Elasticsearch tramite ElasticPress
WORDPRESS_SEARCH_MODE=disabled
WORDPRESS_SEARCH_HOST=
WORDPRESS_SEARCH_CREDENTIALS=
WORDPRESS_SEARCH_INDEX_PREFIX=coolifywp
WORDPRESS_SEARCH_MULTISITE_ACTIVATION=per-site
WORDPRESS_SEARCH_VERIFY=false

# Backup Restic opzionale (attivare il profilo backup solo dopo averlo configurato)
BACKUP_ENABLED=true
BACKUP_AUTO_INIT=false
BACKUP_INTERVAL_SECONDS=86400
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4
BACKUP_KEEP_MONTHLY=6
BACKUP_CHECK_INTERVAL_RUNS=7
RESTIC_REPOSITORY=/repository
RESTIC_PASSWORD=
BACKUP_AWS_ACCESS_KEY_ID=
BACKUP_AWS_SECRET_ACCESS_KEY=
BACKUP_AWS_DEFAULT_REGION=

# Lasciare vuoto per lo stack base; esempi: worker oppure worker,backup
COMPOSE_PROFILES=
